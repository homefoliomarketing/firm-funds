# Firm Funds environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# Every value below is a placeholder. Replace CHANGE_ME with the real secret.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=            # Supabase project URL (client and server)
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # Public anon key for the browser client
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME  # Service role key for server-side mutations that bypass RLS. Server only
SUPABASE_DB_URL=CHANGE_ME            # Postgres connection string (session pooler host), used by npx supabase db query

# --- Site ---
NEXT_PUBLIC_SITE_URL=                # Canonical site URL, used for magic-link and callback redirects

# --- DocuSign ---
DOCUSIGN_INTEGRATION_KEY=CHANGE_ME   # DocuSign integration key (client id)
DOCUSIGN_SECRET_KEY=CHANGE_ME        # DocuSign OAuth secret key
DOCUSIGN_ACCOUNT_ID=CHANGE_ME        # DocuSign account id
DOCUSIGN_AUTH_URL=                   # DocuSign OAuth base URL (account-d.docusign.com for demo)
DOCUSIGN_BASE_URL=                   # DocuSign REST API base URL
DOCUSIGN_REDIRECT_URI=               # OAuth callback URL registered with DocuSign
DOCUSIGN_HMAC_SECRET=CHANGE_ME       # HMAC key used to verify inbound Connect webhooks
DOCUSIGN_HMAC_DEV_BYPASS=            # Set to "true" only in local dev to skip HMAC verification

# --- Resend (email) ---
RESEND_API_KEY=CHANGE_ME             # Resend API key for transactional email

# --- Firm-deal detection (Google Sheets + Anthropic + offer routing) ---
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=CHANGE_ME  # Service account JSON (as a string) for reading the deal pipeline sheet
ANTHROPIC_API_KEY=CHANGE_ME          # Anthropic API key used to parse spreadsheet event rows
FIRM_DEAL_FROM_ADDRESS=              # From address for firm-deal notification emails
FIRM_FUNDS_OFFER_INBOX=              # Inbox address that receives brokerage offer + escalation emails

# --- Twilio (firm-deal SMS) ---
TWILIO_ACCOUNT_SID=CHANGE_ME         # Twilio account SID
TWILIO_API_KEY_SID=CHANGE_ME         # Twilio API key SID
TWILIO_API_KEY_SECRET=CHANGE_ME      # Twilio API key secret
TWILIO_PHONE_NUMBER=                 # Twilio sender phone number (E.164 format)

# --- Upstash Redis (rate limiting) ---
UPSTASH_REDIS_REST_URL=              # Upstash Redis REST URL
UPSTASH_REDIS_REST_TOKEN=CHANGE_ME   # Upstash Redis REST token

# --- Google Maps (address autocomplete) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=CHANGE_ME  # Google Maps JS API key for the address autocomplete field

# --- Cron ---
CRON_SECRET=CHANGE_ME                # Shared secret required by every /api/cron/* endpoint
CRON_BACKFILL_SECRET=CHANGE_ME       # Separate secret for the monthly-broker-statements backfill path

# --- Seed (local/dev only) ---
SEED_SECRET=CHANGE_ME                # Guards the /api/seed route; keep unset in production
