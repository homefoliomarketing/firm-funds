{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "nextjs-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "deck-static",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "http-server", "marketing/decks/commission-advance-pitch", "-p", "8765", "-c-1", "--silent"],
      "port": 8765
    },
    {
      "name": "public-static",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "http-server", "public", "-p", "8770", "-c-1", "--silent"],
      "port": 8770
    }
  ]
}
